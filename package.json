{
  "name": "@hydra-acp/slack",
  "version": "0.1.35",
  "description": "Bridge hydra-acp sessions to Slack threads.",
  "license": "MIT",
  "type": "module",
  "homepage": "https://github.com/smagnuso/hydra-acp-slack#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smagnuso/hydra-acp-slack.git"
  },
  "bugs": {
    "url": "https://github.com/smagnuso/hydra-acp-slack/issues"
  },
  "keywords": [
    "acp",
    "hydra-acp",
    "slack",
    "bolt",
    "agent-client-protocol",
    "claude",
    "codex"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "files": [
    "dist",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "bin": {
    "hydra-acp-slack": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "watch": "tsup --watch",
    "start": "node dist/index.js",
    "dev": "tsup && node dist/index.js",
    "test": "node --test --import tsx 'test/**/*.test.ts'",
    "lint": "tsc -p . --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@slack/bolt": "^4.6.0",
    "node-web-audio-api": "^2.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.6.3"
  }
}
